# ATOM (ROCm/ATOM) code map, version-tagged. One JSON object per line (# lines ignored).
# Schema: {id, area, symptoms[], layouts[ {since, until?, folders[], files[], entry?[], note} ]}
# ATOM is young (adapted from nano-vllm) and ROCm-only. The docs/ guide named in each
# area is authoritative; atom/ module paths are best-effort -- confirm against the checkout.
{"id": "configuration", "area": "Configuration: config classes / CLI arguments / env vars", "symptoms": ["config", "cli argument", "add a flag", "server arg", "kv_cache_dtype", "online_quant_config", "opt level", "configuration", "default value"], "layouts": [{"since": "0.0.0", "folders": ["atom/", "docs/"], "files": ["docs/configuration_guide.md", "atom/config.py"], "entry": ["Config"], "note": "Config classes + CLI args + env vars. docs/configuration_guide.md is authoritative; arg parsing lives in the entrypoints/config (verify path)."}]}
{"id": "entrypoints-server", "area": "Entrypoints / OpenAI-compatible server / profiler endpoints", "symptoms": ["openai server", "openai_server", "/v1/chat/completions", "/v1/completions", "endpoint", "serving", "start_profile", "stop_profile", "launch server", "api"], "layouts": [{"since": "0.0.0", "folders": ["atom/entrypoints/", "docs/"], "files": ["atom/entrypoints/openai_server.py", "docs/serving_benchmarking_guide.md"], "entry": ["python -m atom.entrypoints.openai_server"], "note": "OpenAI-compatible server + /start_profile,/stop_profile. Also atom/examples/simple_inference.py for offline."}]}
{"id": "engine-scheduler", "area": "Engine / scheduler / KV cache / block allocation / prefix caching", "symptoms": ["scheduler", "batching", "kv cache", "block allocation", "block manager", "prefix caching", "xxhash64", "sequence", "engine loop", "preemption"], "layouts": [{"since": "0.0.0", "folders": ["atom/engine/", "docs/"], "files": ["docs/scheduling_kv_cache_guide.md", "atom/engine/scheduler.py", "atom/engine/block_manager.py"], "entry": ["Scheduler", "BlockManager"], "note": "Batch scheduling, block allocation, xxhash64-based prefix caching. nano-vllm-style engine under atom/engine/ (verify); the guide is authoritative."}]}
{"id": "model-runner-compilation", "area": "Model runner / forward / piecewise torch.compile / CUDA graphs", "symptoms": ["model runner", "forward", "torch.compile", "compilation", "piecewise", "cuda graph", "opt level", "optimization level", "compile level", "decode graph"], "layouts": [{"since": "0.0.0", "folders": ["atom/engine/", "docs/"], "files": ["docs/compilation_cudagraph_guide.md", "atom/engine/model_runner.py"], "entry": ["ModelRunner"], "note": "4 piecewise torch.compile levels with CUDA graph capture; default opt level 3. docs/compilation_cudagraph_guide.md is authoritative."}]}
{"id": "models", "area": "Models / add an architecture / weight loading", "symptoms": ["add a model", "new model", "unsupported architecture", "model file", "weight loading", "load weights", "architectures", "port model", "huggingface config"], "layouts": [{"since": "0.0.0", "folders": ["atom/models/", "docs/"], "files": ["docs/model_support_guide.md", "atom/models/llama.py"], "entry": ["load_weights"], "note": "One file per architecture under atom/models/ (verify). Auto-detects HF architecture. Supported: Llama, Qwen3(/MoE/Next), DeepSeek V2/V3, Mixtral, GLM-4/5/5.2, GPT-OSS, Kimi-K2, MiMo-V2."}]}
{"id": "model-ops-aiter", "area": "Model ops / AITER kernel integration (linear/attention/MoE/norm)", "symptoms": ["aiter", "kernel", "asm", "ck", "triton", "linear wrapper", "attention wrapper", "moe wrapper", "rmsnorm", "model ops", "fused op", "operator"], "layouts": [{"since": "0.0.0", "folders": ["atom/layers/", "docs/"], "files": ["docs/model_ops_guide.md", "atom/layers/attention.py", "atom/layers/linear.py"], "entry": ["AITER wrappers"], "note": "ATOM's core value: AITER (ASM/CK/Triton) kernels wrapped as linear/attention/MoE/norm ops. docs/model_ops_guide.md is authoritative."}]}
{"id": "quantization", "area": "Quantization (FP8 / MXFP4 / INT8 / INT4 / online quant)", "symptoms": ["quantization", "fp8", "mxfp4", "int8", "int4", "ptpc-fp8", "online quant", "online_quant_config", "kv_cache_dtype", "auto-detect quant", "mixed precision"], "layouts": [{"since": "0.0.0", "folders": ["atom/", "docs/"], "files": ["docs/configuration_guide.md", "atom/layers/"], "entry": ["--online_quant_config", "--kv_cache_dtype"], "note": "FP8/MXFP4/INT8/INT4 auto-detected from HF config; online re-quant to PTPC-FP8/MXFP4 at load via --online_quant_config. Quant kernels via AITER (see model-ops-aiter)."}]}
{"id": "distributed-tbo", "area": "Distributed: TP/DP/EP, MORI all-to-all, Two-Batch Overlap (TBO)", "symptoms": ["distributed", "tensor parallel", "data parallel", "expert parallel", "tp", "dp", "ep", "mori", "all-to-all", "two-batch overlap", "tbo", "micro-batch", "multi-gpu"], "layouts": [{"since": "0.0.0", "folders": ["atom/distributed/", "docs/"], "files": ["docs/distributed_guide.md"], "entry": ["-tp", "-dp", "-ep"], "note": "TP/DP/EP with MORI all-to-all. TBO splits a batch into two micro-batches to overlap expert-parallel comms with compute (DeepSeek-style). docs/distributed_guide.md is authoritative."}]}
