{"id": "scheduler", "area": "Scheduler / batch scheduling / overlap scheduler / preemption", "symptoms": ["scheduler", "batching", "schedule batch", "schedule policy", "overlap schedule", "continuous batching", "preemption", "max-running-requests", "schedule conservativeness", "waiting queue", "which requests run"], "layouts": [{"since": "0.0.0", "folders": ["python/sglang/srt/managers/"], "files": ["python/sglang/srt/managers/scheduler.py", "python/sglang/srt/managers/schedule_batch.py", "python/sglang/srt/managers/schedule_policy.py"], "entry": ["Scheduler", "Scheduler.event_loop_overlap", "ScheduleBatch", "SchedulePolicy"], "note": "Zero-overlap scheduler: event loop, batch formation, and policy (lpm/fcfs/dfs-weight). Overlap of CPU schedule with GPU compute is here."}]}
{"id": "tokenizer-manager", "area": "Tokenizer manager / detokenizer manager (process IPC)", "symptoms": ["tokenizer manager", "detokenizer", "tokenization", "detokenization", "request intake", "zmq", "incremental detokenize", "tokenizer process"], "layouts": [{"since": "0.0.0", "folders": ["python/sglang/srt/managers/"], "files": ["python/sglang/srt/managers/tokenizer_manager.py", "python/sglang/srt/managers/detokenizer_manager.py"], "entry": ["TokenizerManager", "DetokenizerManager"], "note": "SGLang runs tokenizer, scheduler, and detokenizer as separate processes communicating over ZMQ."}]}
{"id": "radix-cache", "area": "RadixAttention / KV memory pool / prefix cache / HiCache", "symptoms": ["radix attention", "radix cache", "prefix caching", "kv cache", "memory pool", "token to kv pool", "chunk cache", "cache reuse", "hicache", "disable-radix-cache", "tree cache", "eviction"], "layouts": [{"since": "0.0.0", "folders": ["python/sglang/srt/mem_cache/"], "files": ["python/sglang/srt/mem_cache/radix_cache.py", "python/sglang/srt/mem_cache/memory_pool.py", "python/sglang/srt/mem_cache/chunk_cache.py", "python/sglang/srt/mem_cache/base_prefix_cache.py"], "entry": ["RadixCache", "TokenToKVPool", "ReqToTokenPool"], "note": "RadixAttention = automatic KV reuse via a radix tree (more general than hash-based APC; supports fork/tree sharing). KV pools live here."}]}
