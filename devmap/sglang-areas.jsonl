# SGLang code map, version-tagged. One JSON object per line (# lines ignored).
# Schema: {id, area, symptoms[], layouts[ {since, until?, folders[], files[], entry?[], note} ]}
# Serving runtime lives under python/sglang/srt (often called "SRT"); frontend DSL under python/sglang/lang.
{"id": "server-args", "area": "Server arguments / CLI flags (ServerArgs)", "symptoms": ["add a flag", "server arg", "cli option", "launch_server flag", "argument", "mem-fraction-static", "tp-size", "chunked-prefill-size", "default value"], "layouts": [{"since": "0.0.0", "folders": ["python/sglang/srt/"], "files": ["python/sglang/srt/server_args.py"], "entry": ["ServerArgs", "ServerArgs.add_cli_args", "prepare_server_args"], "note": "Every launch flag maps to a ServerArgs field; declare new flags here."}]}
